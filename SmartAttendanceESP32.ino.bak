/*
 * SmartAttendanceESP32 (Bus Unit)
 * Purpose: Independent Bus Attendance System with WiFi Logging + GSM SMS +
 * Feedback (LED/Buzzer)
 *
 * Update: Added Green/Red LED and Buzzer Logic.
 */

#include <HTTPClient.h>
#include <HardwareSerial.h>
#include <MFRC522.h>
#include <Preferences.h>
#include <SPI.h>
#include <WiFi.h>

// ----------------------------------------------------------------------
// CONFIGURATION
// ----------------------------------------------------------------------
const char *ssid = "Fiber";
const char *password = "Suneth@512";

// GOOGLE SCRIPT URL
String GOOGLE_SCRIPT_URL = "https://script.google.com/macros/s/"
                           "AKfycby8QjOohMtw2NpOMpLytM2_LI-"
                           "lwb39g3Cc2Kaj7FTaRMUb6O744m2mm1uv3724IqY/exec";

// PARENT PHONE (Default - In a real system you'd fetch this from the cloud)
String DEFAULT_PHONE = "+94772010915";

// PINS - RFID (Standard VSPI)
#define SS_PIN 5
#define RST_PIN 22

// PINS - GSM (Serial2)
#define RX_PIN 16
#define TX_PIN 17

// PINS - FEEDBACK
#define PIN_LED_GREEN 25
#define PIN_LED_RED 26
#define PIN_BUZZER 13

// ----------------------------------------------------------------------
// GLOBAL OBJECTS
// ----------------------------------------------------------------------
MFRC522 rfid(SS_PIN, RST_PIN);
HardwareSerial gsmSerial(2); // UART2
Preferences preferences;     // To save entry/exit state permanently

void setup() {
  Serial.begin(115200);

  // 0. Init Feedback Pins
  pinMode(PIN_LED_GREEN, OUTPUT);
  pinMode(PIN_LED_RED, OUTPUT);
  pinMode(PIN_BUZZER, OUTPUT);
  digitalWrite(PIN_LED_GREEN, LOW);
  digitalWrite(PIN_LED_RED, LOW);
  digitalWrite(PIN_BUZZER, LOW);

  // 1. Init status storage
  preferences.begin("attendance", false);

  // 2. Init RFID
  SPI.begin();
  rfid.PCD_Init();
  Serial.println("RFID Ready");

  // 3. Init GSM
  gsmSerial.begin(9600, SERIAL_8N1, RX_PIN, TX_PIN);
  delay(3000);

  Serial.println("--- GSM SETUP START ---");

  // Factory Reset GSM Settings
  gsmSerial.println("AT&F");
  delay(1000);

  // A. Handshake
  bool gsmReady = false;
  for (int i = 0; i < 5; i++) {
    gsmSerial.println("AT");
    delay(500);
    if (gsmSerial.available()) {
      gsmReady = true;
      break;
    }
  }

  if (gsmReady) {
    Serial.println("GSM Hardware Detected.");

    // B. Check SIM Status
    gsmSerial.println("AT+CPIN?");
    delay(1000);
    while (gsmSerial.available())
      Serial.write(gsmSerial.read());

    // C. Check Signal/Network
    gsmSerial.println("AT+CREG?");
    delay(1000);
    while (gsmSerial.available())
      Serial.write(gsmSerial.read());

    // D. Set Text Mode
    gsmSerial.println("AT+CMGF=1");
    delay(1000);
    while (gsmSerial.available())
      Serial.write(gsmSerial.read());

  } else {
    Serial.println("GSM HARDWARE FAILURE (No Response)");
  }
  Serial.println("--- GSM SETUP DONE ---");

  // 4. Init WiFi
  WiFi.begin(ssid, password);
  Serial.print("Connecting to WiFi: ");
  Serial.println(ssid);

  int timeout = 0;
  // Increase timeout to 60 half-seconds (30 seconds)
  while (WiFi.status() != WL_CONNECTED && timeout < 60) {
    delay(500);
    Serial.print(".");
    timeout++;
  }

  if (WiFi.status() == WL_CONNECTED) {
    Serial.println("\n--- WiFi Connected! ---");
    Serial.print("IP Address: ");
    Serial.println(WiFi.localIP());
    // Visual confirm: Green blink
    digitalWrite(PIN_LED_GREEN, HIGH);
    delay(200);
    digitalWrite(PIN_LED_GREEN, LOW);
  } else {
    Serial.println("\n[ERROR] WiFi Failed to Connect.");
    // Visual error: Red blink
    digitalWrite(PIN_LED_RED, HIGH);
    delay(200);
    digitalWrite(PIN_LED_RED, LOW);
  }
}

void loop() {
  // Check for RFID
  if (!rfid.PICC_IsNewCardPresent())
    return;
  if (!rfid.PICC_ReadCardSerial())
    return;

  // 1. Get UID (Comma Separated Decimal to match Pi/Sheet)
  String uid = "";
  for (byte i = 0; i < rfid.uid.size; i++) {
    if (i > 0)
      uid += ",";
    uid += String(rfid.uid.uidByte[i]);
  }

  Serial.println("\nCard Detected: " + uid);

  // Auditory: Short beep to acknowledge scan
  digitalWrite(PIN_BUZZER, HIGH);
  delay(50);
  digitalWrite(PIN_BUZZER, LOW);

  // 2. Handle Logic (Entry/Exit)
  handleStudentScan(uid);

  // Halt PICC
  rfid.PICC_HaltA();
  rfid.PCD_StopCrypto1();
  delay(2000); // 2 second delay to prevent immediate double-read
}

void handleStudentScan(String uid) {
  // Check last status
  // 0 = Outside (Default), 1 = Inside
  int currentStatus = preferences.getInt(uid.c_str(), 0);

  String action = (currentStatus == 0) ? "BUS_ENTRY" : "BUS_EXIT";
  String smsMsg = (currentStatus == 0) ? "Student has BOARDED the Bus."
                                       : "Student has GOT OFF the Bus.";

  // Toggle Status
  preferences.putInt(uid.c_str(), (currentStatus == 0) ? 1 : 0);

  Serial.println("Action: " + action);

  // 3. Send Data to Cloud (WiFi)
  if (WiFi.status() == WL_CONNECTED) {
    sendDataToScript(uid, action);
  } else {
    Serial.println("WiFi Offline - Log NOT synced to Sheet.");
    triggerFail(); // Indicate failure to sync (optional, or just ignore)
  }
}

void sendDataToScript(String uid, String type) {
  HTTPClient http;

  // Construct GET URL with Query Params
  // Use 'handleScan' which does everything on the server
  String url = GOOGLE_SCRIPT_URL + "?action=handleScan" + "&uid=" + uid +
               "&device=BUS-UNIT-01" + "&type=" + type;

  Serial.println("Sending Request: " + url);

  http.begin(url);
  http.setFollowRedirects(HTTPC_STRICT_FOLLOW_REDIRECTS);

  int httpResponseCode = http.GET();

  if (httpResponseCode > 0) {
    String payload = http.getString();
    Serial.println("Cloud Response: " + payload);

    if (payload.indexOf("\"allowed\"") > 0) {
      // --- ACCESS GRANTED ---
      Serial.println(">>> ACCESS GRANTED <<<");
      triggerSuccess(); // Green LED + Beep Beep

      // Extract Phone
      int phoneStart = payload.indexOf("\"phone\":\"") + 9;
      int phoneEnd = payload.indexOf("\"", phoneStart);
      String phone = payload.substring(phoneStart, phoneEnd);

      // Extract Name
      int nameStart = payload.indexOf("\"name\":\"") + 8;
      int nameEnd = payload.indexOf("\"", nameStart);
      String name = payload.substring(nameStart, nameEnd);

      Serial.println("Student: " + name);
      Serial.println("Phone: " + phone);

      // Send SMS to the ACTUAL PARENT
      String smsMsg = "";
      if (type == "BUS_ENTRY")
        smsMsg = "Alert: " + name + " has BOARDED the School Bus.";
      else
        smsMsg = "Alert: " + name + " has GOT OFF the School Bus.";

      sendSMS(phone, smsMsg);

    } else if (payload.indexOf("\"denied\"") > 0) {
      // --- ACCESS DENIED ---
      Serial.println(">>> ACCESS DENIED (Unknown Card) <<<");
      triggerFail(); // Red LED + Long Beep

    } else {
      Serial.println("Unknown Response format");
      triggerFail(); // Treat unknown as fail
    }

  } else {
    Serial.print("Error on sending GET: ");
    Serial.println(httpResponseCode);
    triggerFail(); // Network Error
  }
  http.end();
}

void sendSMS(String number, String message) {
  Serial.println("--- Initiating SMS ---");

  // 1. Set to Text Mode
  gsmSerial.println("AT+CMGF=1");
  delay(500);
  while (gsmSerial.available())
    Serial.write(gsmSerial.read()); // Print response

  // 2. Start Message
  Serial.print("Sending to: ");
  Serial.println(number);

  gsmSerial.print("AT+CMGS=\"");
  gsmSerial.print(number);
  gsmSerial.println("\"");

  delay(1000); // Wait for '>' prompt
  while (gsmSerial.available())
    Serial.write(gsmSerial.read()); // Print response (should see >)

  // 3. Send Body
  gsmSerial.print(message);
  delay(100);
  gsmSerial.write(26); // Ctrl+Z

  Serial.println("\nWaiting for transmission...");
  delay(5000); // long wait for network

  // 4. Read Final Result
  while (gsmSerial.available()) {
    Serial.write(gsmSerial.read());
  }
  Serial.println("\n--- SMS Process Finished ---");
}

// --- FEEDBACK HELPERS ---

void triggerSuccess() {
  // Green Light ON
  digitalWrite(PIN_LED_GREEN, HIGH);

  // Beep Beep
  digitalWrite(PIN_BUZZER, HIGH);
  delay(100);
  digitalWrite(PIN_BUZZER, LOW);
  delay(100);
  digitalWrite(PIN_BUZZER, HIGH);
  delay(100);
  digitalWrite(PIN_BUZZER, LOW);

  // Keep Green ON for a moment
  delay(1000);
  digitalWrite(PIN_LED_GREEN, LOW);
}

void triggerFail() {
  // Red Light ON
  digitalWrite(PIN_LED_RED, HIGH);

  // Long Alarm
  digitalWrite(PIN_BUZZER, HIGH);
  delay(1000); // 1 Second long beep
  digitalWrite(PIN_BUZZER, LOW);

  digitalWrite(PIN_LED_RED, LOW);
}
